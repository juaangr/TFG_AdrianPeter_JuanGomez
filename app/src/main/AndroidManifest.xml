<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".RealmApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/sports_go_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SportsGO"> <!-- 1. ASEGÚRATE QUE ESTE TEMA EXISTE EN THEMES.XML -->

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 2. AÑADIDO EXPORTED=FALSE POR SEGURIDAD -->
        <activity
            android:name=".PupilHomeActivity"
            android:exported="false" />

        <activity
            android:name=".PupilWorkoutActivity"
            android:exported="false" />

    </application>

</manifest>