        <activity
            android:name=".TrainerDashboardActivity"
            android:exported="false" />

        <activity
            android:name=".TrainerStatsActivity"
            android:exported="false" />

        <activity
            android:name=".ExerciseBankActivity"
            android:exported="false" />

        <activity
            android:name=".DashboardActivity"
            android:exported="false" />

        <activity
            android:name=".ProfileActivity"
            android:exported="false" />

        <activity
            android:name=".ChatActivity"
            android:exported="false" />

        <activity
            android:name=".TabataActivity"
            android:exported="false" />

        <activity
            android:name=".IMCActivity"
            android:exported="false" />

        <activity
            android:name=".logins.UserLoginActivity">
        </activity>

        <activity
            android:name=".ElegirLoginActivity">
        </activity>

        <activity
            android:name=".logins.AdminLoginActivity">
        </activity>

        <activity
            android:name=".logins.TrainerLoginActivity">
