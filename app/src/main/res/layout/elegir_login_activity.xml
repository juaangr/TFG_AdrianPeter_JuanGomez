<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/elegir_login_activity"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- PENDIENTE DE REFACTORIZAR LAS STRINGS HARDCODEADAS (DEBERÍAMOS USAR VALUES/STRINGS¿?¿?¿?
    También poner fondo de pantalla dependiendo del tema del teléfono por defecto
    se podrá cambiar en los ajustes de la app.....?????-->

    <TextView
        android:id="@+id/tvElegir"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="500dp"
        android:fontFamily="serif"
        android:text="¿Qúe tipo de usuario eres?"

        android:textSize="30dp"
        android:textStyle="italic"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

    </TextView>

    <LinearLayout
        android:id="@+id/linearElegir"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="-80dp">

        <Button
            android:id="@+id/btnUser"
            android:layout_width="155dp"
            android:layout_height="wrap_content"
            android:text="USUARIO"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:layout_margin="20dp">
        </Button>

        <Button
            android:id="@+id/btnTrainer"
            android:layout_width="155dp"
            android:layout_height="wrap_content"
            android:text="ENTRENADOR"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:layout_margin="20dp">
        </Button>

        <Button
            android:id="@+id/btnAdmin"
            android:text="ADMIN"
            android:layout_width="155dp"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:layout_margin="20dp">
        </Button>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/tvPreguntaRegistro"
        android:text="¿Ya tienes una cuenta? Regístrate"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/imgLogoElegir"
        app:layout_constraintTop_toBottomOf="@+id/linearElegir">
    </TextView>

    <ImageView
        android:id="@+id/imgLogoElegir"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/sportgo_logo"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearElegir">
    </ImageView>

</androidx.constraintlayout.widget.ConstraintLayout>