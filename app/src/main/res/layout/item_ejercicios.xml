<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:background="@android:color/white"
    android:elevation="2dp"
    android:orientation="horizontal"
    android:padding="12dp"
    android:id="@+id/btnEjercicio">
    <!-- Espacio para la foto del ejercicio -->
    <ImageView
        android:id="@+id/imgEjercicio"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:scaleType="centerCrop"
        android:src="@mipmap/ic_launcher" />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:orientation="vertical">
        <TextView
            android:id="@+id/txtNombreEj"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre"
            android:textColor="#212121"
            android:textSize="18sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/txtDetallesEj"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4 series x 12 reps"
            android:textColor="#616161" />
        <TextView
            android:id="@+id/txtPesoEj"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Peso inicial: 10kg"
            android:textColor="#FF5722"
            android:textStyle="bold" />
        <CheckBox
            android:id="@+id/cbCompletado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hecho"
            android:layout_marginTop="8dp"/>
    </LinearLayout>
</LinearLayout>