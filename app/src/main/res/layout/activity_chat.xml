<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <!-- Barra Superior (Taskbar del Chat) -->
    <LinearLayout
        android:id="@+id/chatHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A202C"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvNombreChat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre del Usuario"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/viewEstadoColor"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@android:color/darker_gray" />

            <TextView
                android:id="@+id/tvEstadoTexto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Desconectado"
                android:textColor="#E2E8F0"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Lista de Mensajes -->
    <ListView
        android:id="@+id/lvMensajes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/layoutEnvio"
        android:layout_below="@id/chatHeader"
        android:divider="@null"
        android:padding="10dp"
        android:stackFromBottom="true"
        android:transcriptMode="alwaysScroll" />

    <!-- Barra de entrada de texto -->
    <LinearLayout
        android:id="@+id/layoutEnvio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:padding="8dp">

        <EditText
            android:id="@+id/etMensaje"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Escribe un mensaje..."
            android:padding="12dp" />

        <ImageButton
            android:id="@+id/btnEnviarMsg"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_send" />
    </LinearLayout>
</RelativeLayout>