<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0e0e0e"
    android:padding="20dp">

    <!-- Blur background approximation -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="#cafd00"
        android:alpha="0.05"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#131313"
        app:cardCornerRadius="16dp"
        app:cardElevation="24dp"
        app:strokeColor="#33cafd00"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="32dp">

            <!-- Icon -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:cardBackgroundColor="#262626"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#26484847"
                app:strokeWidth="1dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_secure"
                    app:tint="#cafd00" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Headline -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:letterSpacing="-0.02"
                android:lineSpacingExtra="-4dp"
                android:textAllCaps="true"
                android:textSize="28sp"
                android:textColor="#FFFFFF"
                android:text="TU PRIVACIDAD ES\n" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:letterSpacing="-0.02"
                android:lineSpacingExtra="-4dp"
                android:textAllCaps="true"
                android:textSize="28sp"
                android:textColor="#cafd00"
                android:text="NUESTRA META" />

            <!-- Body -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:lineHeight="22sp"
                android:text="Para que tu experiencia en SportsGo sea de élite, necesitamos usar cookies para guardar tu perfil y estadísticas. Al continuar, aceptas nuestra política de privacidad."
                android:textColor="#adaaaa"
                android:textSize="15sp" />

            <!-- Checkbox -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center_vertical|center_horizontal"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/cbAceptar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:buttonTint="#cafd00"
                    android:checked="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.05"
                    android:text="ACEPTO LOS TÉRMINOS Y EL\nUSO DE COOKIES"
                    android:textColor="#adaaaa"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAceptar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:text="ACEPTAR Y CONTINUAR"
                android:textColor="#0e0e0e"
                android:textSize="14sp"
                app:backgroundTint="#cafd00"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
