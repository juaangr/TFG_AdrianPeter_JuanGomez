<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kinetic_surface"
    android:padding="20dp">

    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@android:drawable/screen_background_dark"
        android:backgroundTint="@color/kinetic_accent_blur"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/kinetic_card"
        app:cardCornerRadius="24dp"
        app:cardElevation="20dp"
        app:strokeColor="#33FFFFFF"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="32dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="80dp"
                android:layout_height="80dp"
                app:cardBackgroundColor="#262626"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/kinetic_primary"
                app:strokeWidth="1dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_report_image"
                    app:tint="@color/kinetic_primary" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:letterSpacing="-0.02"
                android:lineSpacingExtra="-4dp"
                android:text="TU PRIVACIDAD ES\nNUESTRA META"
                android:textAllCaps="true"
                android:textColor="#FFFFFF"
                android:textSize="28sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:lineHeight="22sp"
                android:text="Para que tu experiencia en SportsGo sea de élite, necesitamos usar cookies para guardar tu perfil y estadísticas."
                android:textColor="@color/kinetic_text_gray"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/cbAceptar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/kinetic_primary"
                    android:checked="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"
                    android:text="ACEPTO LOS TÉRMINOS"
                    android:textColor="@color/kinetic_text_gray"
                    android:textSize="10sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAceptar"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:text="ACEPTAR Y CONTINUAR"
                android:textColor="@color/kinetic_surface"
                android:textSize="16sp"
                app:backgroundTint="@color/kinetic_primary"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>