<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_graffiti_neon"> <!-- Fondo Kinetic Neón -->

    <!-- CABECERA PREMIUM -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#131313"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/userProfile"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:padding="2dp"
            android:src="@drawable/sportgo_logo"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeColor="@color/kinetic_primary"
            app:strokeWidth="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02"
            android:text="SportsGO"
            android:textColor="@color/kinetic_primary"
            android:textSize="24sp"
            android:textStyle="italic"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/userProfile"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnIAHeader"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_help"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/kinetic_primary" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- BARRA NAVEGACIÓN INFERIOR (Estilo Flotante con Borde) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_nav_card"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:layout_margin="20dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="38dp"
        app:cardElevation="20dp"
        app:strokeColor="@color/kinetic_primary"
        app:strokeWidth="2dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnLogout"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_popup_sync"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/kinetic_primary" />

            <ImageView
                android:id="@+id/btnSearch"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/kinetic_text_gray" />

            <ImageView
                android:id="@+id/btnNavChat"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:src="@android:drawable/stat_notify_chat"
                app:tint="@color/kinetic_text_gray" />

            <ImageView
                android:id="@+id/btnNavPerfil"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/kinetic_text_gray" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- CUERPO SCROLLABLE -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav_card"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvBienvenida"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:lineSpacingExtra="-10dp"
                android:text="HOLA,\nADRIAN"
                android:textColor="@color/kinetic_primary"
                android:textSize="55sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.3"
                android:text="TU PRÓXIMO NIVEL ESTÁ AQUÍ"
                android:textColor="@color/kinetic_text_gray"
                android:textSize="12sp" />

            <!-- CONTENEDOR DE BOTONES PRINCIPALES -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp">

                <!-- BOTÓN ENTRENAR -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWorkout"
                    android:layout_width="0dp"
                    android:layout_height="280dp"
                    android:layout_marginEnd="10dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="30dp"
                    app:cardElevation="8dp"
                    app:strokeColor="@color/kinetic_primary"
                    app:strokeWidth="2.5dp"
                    app:layout_constraintEnd_toStartOf="@+id/guideline"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Imagen -->
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:alpha="0.6"
                            android:scaleType="centerCrop"
                            android:src="@drawable/segundo_activity" />

                        <!-- Borde encima como overlay -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/border_image" />

                        <!-- Texto encima -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="bottom"
                            android:orientation="vertical"
                            android:padding="20dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@color/kinetic_primary"
                                android:paddingHorizontal="6dp"
                                android:text=" ENTRENAR "
                                android:fontFamily="sans-serif-black"
                                android:textColor="#000000"
                                android:textSize="10sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Mis\nRutinas"
                                android:textColor="#FFFFFF"
                                android:textSize="24sp"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- BOTONES LATERALES -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="280dp"
                    android:layout_marginStart="10dp"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/cardWorkout"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardChat"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginBottom="10dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#1A1A1A"
                        app:cardCornerRadius="25dp"
                        app:cardElevation="8dp"
                        app:strokeColor="@color/kinetic_primary"
                        app:strokeWidth="2dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="35dp"
                                android:layout_height="35dp"
                                android:src="@android:drawable/stat_notify_chat"
                                app:tint="@color/kinetic_primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="CHAT"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPerfil"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="10dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#1A1A1A"
                        app:cardCornerRadius="25dp"
                        app:cardElevation="8dp"
                        app:strokeColor="@color/kinetic_secondary"
                        app:strokeWidth="2dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="35dp"
                                android:layout_height="35dp"
                                android:src="@android:drawable/ic_menu_myplaces"
                                app:tint="@color/kinetic_secondary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="PERFIL"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guideline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.55" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- BOTONES HORIZONTALES LARGOS -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCalorias"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="25dp"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="25dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/kinetic_secondary"
                app:strokeWidth="2dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="25dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tagNut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="METABOLISMO"
                        android:textColor="@color/kinetic_secondary"
                        android:fontFamily="sans-serif-black"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tagNut"
                        android:text="Calculadora de Calorías"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTabata"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="15dp"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="25dp"
                app:cardElevation="8dp"
                app:strokeColor="#00E5FF"
                app:strokeWidth="2dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="25dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tagTab"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ENTRENAMIENTO HIIT"
                        android:textColor="#00E5FF"
                        android:fontFamily="sans-serif-black"
                        android:textSize="11sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tagTab"
                        android:text="Tabata Timer"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardIMC"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="30dp"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="25dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/kinetic_secondary"
                app:strokeWidth="2dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="25dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tagIMC"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="COMPOSICIÓN"
                        android:textColor="@color/kinetic_secondary"
                        android:fontFamily="sans-serif-black"
                        android:textSize="11sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tagIMC"
                        android:text="Calculadora IMC"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
