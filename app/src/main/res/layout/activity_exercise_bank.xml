<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_graffiti_neon"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.appbar.MaterialToolbar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/kinetic_card"
        app:title="@string/exercise_bank_title"
        app:titleTextColor="@color/kinetic_on_surface" />

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.SportsGO.KineticCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/exercise_bank_subtitle"
                android:textColor="@color/kinetic_text_gray" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Spinner
                    android:id="@+id/spinnerFiltroCategoria"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/border_image" />

                <Spinner
                    android:id="@+id/spinnerFiltroGrupo"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/border_image" />
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.SportsGO.KineticInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="@string/exercise_bank_search_hint"
                app:startIconDrawable="@android:drawable/ic_menu_search"
                app:startIconTint="@color/kinetic_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBuscarPlantilla"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/kinetic_on_surface"
                    android:textColorHint="@color/kinetic_text_gray" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNuevaPlantilla"
                    style="@style/Widget.SportsGO.KineticButtonPrimary"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/exercise_bank_new_template"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCerrarBanco"
                    style="@style/Widget.SportsGO.KineticButtonDark"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/common_close"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.SportsGO.KineticCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/black">

        <ListView
            android:id="@+id/lvPlantillasEjercicios"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/black"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp"
            android:padding="10dp" />
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
