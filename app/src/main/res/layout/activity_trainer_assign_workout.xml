<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_assign_workout_focus"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarAssignWorkout"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/kinetic_card"
        android:elevation="6dp"
        android:minHeight="?attr/actionBarSize"
        app:title="@string/trainer_assign_title"
        app:titleCentered="true"
        app:titleTextColor="@color/kinetic_on_surface" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_weight="1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F2101010"
        android:orientation="vertical"
        android:padding="20dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivBanner"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="12dp"
            android:alpha="0.9"
            android:scaleType="centerCrop"
            android:src="@drawable/segundo_activity"
            app:shapeAppearanceOverlay="@style/RoundedBottomCorners" />

        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:shadowColor="@color/black"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="10"
            android:text="@string/trainer_assign_header"
            android:textColor="@color/kinetic_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNombreAlumno"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/trainer_assign_student_label"
            android:textColor="@color/kinetic_on_surface"
            android:textSize="15sp" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SportsGO.KineticCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/kinetic_card"
            app:strokeColor="@color/kinetic_border"
            app:strokeWidth="2dp"
            app:cardElevation="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/trainer_assign_group_label"
                    android:textColor="@color/kinetic_on_surface"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAbrirBanco"
                    style="@style/Widget.SportsGO.KineticButtonDark"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="12dp"
                    android:text="@string/trainer_assign_open_bank"
                    android:textAllCaps="false"
                    app:icon="@android:drawable/ic_menu_agenda"
                    app:iconTint="@color/kinetic_primary"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    />

                <Spinner
                    android:id="@+id/spinnerGrupoMuscular"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/spinner_kinetic_bg"
                    android:elevation="2dp"
                    android:prompt="@string/prompt_grupo_muscular"
                    android:popupBackground="@color/kinetic_card" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/trainer_assign_category_label"
                    android:textColor="@color/kinetic_on_surface"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerCategoria"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/spinner_kinetic_bg"
                    android:elevation="2dp"
                    android:prompt="@string/prompt_categoria"
                    android:popupBackground="@color/kinetic_card"
                    />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.SportsGO.KineticInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/trainer_assign_exercise_hint"
                    app:placeholderText="@string/trainer_assign_exercise_placeholder"
                    app:boxBackgroundMode="filled"
                    app:boxBackgroundColor="@color/kinetic_surface"
                    app:boxStrokeColor="@color/kinetic_primary"
                    app:boxStrokeWidth="2dp"
                    app:boxStrokeWidthFocused="3dp"
                    app:hintTextColor="@color/kinetic_on_surface"
                    app:startIconDrawable="@android:drawable/ic_menu_edit"
                    app:startIconTint="@color/kinetic_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNombreEj"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textColor="@color/kinetic_on_surface"
                        android:textColorHint="@color/kinetic_on_surface" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.SportsGO.KineticInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="@string/trainer_assign_weight_hint"
                    app:placeholderText="@string/trainer_assign_weight_placeholder"
                    app:boxBackgroundMode="filled"
                    app:boxBackgroundColor="@color/kinetic_surface"
                    app:boxStrokeColor="@color/kinetic_primary"
                    app:boxStrokeWidth="2dp"
                    app:boxStrokeWidthFocused="3dp"
                    app:hintTextColor="@color/kinetic_on_surface"
                    app:startIconDrawable="@android:drawable/ic_dialog_map"
                    app:startIconTint="@color/kinetic_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPesoEj"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textSize="16sp"
                        android:textColor="@color/kinetic_on_surface"
                        android:textColorHint="@color/kinetic_on_surface" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.SportsGO.KineticInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/trainer_assign_series_hint"
                        app:placeholderText="@string/trainer_assign_series_placeholder"
                        app:boxBackgroundMode="filled"
                        app:boxBackgroundColor="@color/kinetic_surface"
                        app:boxStrokeColor="@color/kinetic_primary"
                        app:boxStrokeWidth="2dp"
                        app:boxStrokeWidthFocused="3dp"
                        app:hintTextColor="@color/kinetic_on_surface">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSeries"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:inputType="number"
                            android:textSize="16sp"
                            android:textColor="@color/kinetic_on_surface" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        android:text="@string/common_multiply"
                        android:textColor="@color/kinetic_primary"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.SportsGO.KineticInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/trainer_assign_reps_hint"
                        app:placeholderText="@string/trainer_assign_reps_placeholder"
                        app:boxBackgroundMode="filled"
                        app:boxBackgroundColor="@color/kinetic_surface"
                        app:boxStrokeColor="@color/kinetic_primary"
                        app:boxStrokeWidth="2dp"
                        app:boxStrokeWidthFocused="3dp"
                        app:hintTextColor="@color/kinetic_on_surface">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etReps"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:inputType="number"
                            android:textSize="16sp"
                            android:textColor="@color/kinetic_on_surface" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <CheckBox
                    android:id="@+id/cbGuardarPlantilla"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:buttonTint="@color/kinetic_primary"
                    android:text="@string/trainer_assign_save_template"
                    android:textColor="@color/kinetic_on_surface" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAsignar"
                    style="@style/Widget.SportsGO.KineticButtonPrimary"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="32dp"
                    android:text="@string/trainer_assign_send"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    android:textColor="#FFFFFF"
                    />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
    </ScrollView>
</LinearLayout>
