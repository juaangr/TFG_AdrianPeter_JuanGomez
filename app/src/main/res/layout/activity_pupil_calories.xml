<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kinetic_surface"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="0dp">

        <ImageView
            android:id="@+id/ivFondo"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:alpha="0.3"
            android:scaleType="centerCrop"
            android:src="@drawable/gym_foto"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/headerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#B30E0E0E"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvBienvenida"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.03"
                android:text="¡Bienvenido a SportsGO!"
                android:textColor="@color/kinetic_primary"
                android:textSize="26sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDatos"
            style="@style/Widget.SportsGO.KineticCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="20dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/kinetic_border"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/headerContainer">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_assign_workout_focus"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:text="Datos Corporales"
                    android:textColor="@color/kinetic_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.SportsGO.KineticInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Altura (cm)"
                    android:textColorHint="@color/common_google_signin_btn_text_light"
                    app:boxBackgroundColor="@color/kinetic_card_alt"
                    app:boxStrokeColor="@color/kinetic_primary"
                    app:boxStrokeWidth="1dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:startIconDrawable="@android:drawable/ic_menu_sort_by_size"
                    app:startIconTint="@color/kinetic_text_gray">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAltura"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="@color/kinetic_on_surface" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.SportsGO.KineticInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Peso (kg)"
                    app:boxBackgroundColor="@color/kinetic_card_alt"
                    app:boxStrokeColor="@color/kinetic_primary"
                    app:boxStrokeWidth="1dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:startIconDrawable="@android:drawable/ic_menu_set_as"
                    app:startIconTint="@color/kinetic_text_gray">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPeso"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/kinetic_on_surface" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.SportsGO.KineticInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Edad (años)"
                    app:boxBackgroundColor="@color/kinetic_card_alt"
                    app:boxStrokeColor="@color/kinetic_primary"
                    app:boxStrokeWidth="1dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                    app:startIconTint="@color/kinetic_text_gray">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEdad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="@color/kinetic_on_surface" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.SportsGO.KineticInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Objetivo Personal"
                    app:boxBackgroundColor="@color/kinetic_card_alt"
                    app:boxStrokeColor="@color/kinetic_primary"
                    app:boxStrokeWidth="1dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp">

                    <AutoCompleteTextView
                        android:id="@+id/spinnerObjetivo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:padding="16dp"
                        android:textColor="@color/kinetic_on_surface" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Género"
                    android:textColor="@color/kinetic_on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgSexo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbHombre"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/kinetic_primary"
                        android:text="Hombre"
                        android:textColor="@color/kinetic_text_gray" />

                    <RadioButton
                        android:id="@+id/rbMujer"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/kinetic_primary"
                        android:text="Mujer"
                        android:textColor="@color/kinetic_text_gray" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardActividad"
            style="@style/Widget.SportsGO.KineticCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/kinetic_border"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/cardDatos">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_assign_workout_focus"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Nivel de Actividad Diaria"
                    android:textColor="@color/kinetic_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgActividad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rbSedentario"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:buttonTint="@color/kinetic_primary"
                        android:text="Sedentario (Oficina/Reposo)"
                        android:textColor="@color/kinetic_text_gray" />

                    <RadioButton
                        android:id="@+id/rbLigero"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:buttonTint="@color/kinetic_primary"
                        android:text="Ligero (1-3 días/sem)"
                        android:textColor="@color/kinetic_text_gray" />

                    <RadioButton
                        android:id="@+id/rbModerado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:buttonTint="@color/kinetic_primary"
                        android:text="Moderado (3-5 días/sem)"
                        android:textColor="@color/kinetic_text_gray" />

                    <RadioButton
                        android:id="@+id/rbFuerte"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/kinetic_primary"
                        android:text="Fuerte (6-7 días/sem)"
                        android:textColor="@color/kinetic_text_gray" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCalcular"
            style="@style/Widget.SportsGO.KineticButtonPrimary"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:textColor="#FFFFFF"
            android:background="@drawable/border_image"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="20dp"
            android:fontFamily="sans-serif-black"
            android:text="CALCULAR TMB"
            android:textSize="28sp"
            app:layout_constraintTop_toBottomOf="@id/cardActividad" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/resultCard"
            style="@style/Widget.SportsGO.KineticCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:strokeColor="@color/kinetic_border"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/btnCalcular">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="67dp"
                android:background="@drawable/bg_assign_workout_focus"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="32dp"
                android:paddingVertical="20dp">

                <TextView
                    android:id="@+id/txtView2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Calorías diarias: -- kcal"
                    android:textColor="@color/kinetic_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinuar"
            style="@style/Widget.SportsGO.KineticButtonDark"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="32dp"
            android:fontFamily="sans-serif-black"
            android:text="VER MIS ENTRENAMIENTOS"
            android:textSize="24sp"
            android:background="@drawable/border_image"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/resultCard" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
