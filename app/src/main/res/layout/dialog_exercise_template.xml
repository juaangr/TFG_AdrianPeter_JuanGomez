<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/kinetic_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.SportsGO.KineticInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombre del ejercicio">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNombrePlantilla"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/kinetic_on_surface" />
        </com.google.android.material.textfield.TextInputLayout>

        <Spinner
            android:id="@+id/spinnerCategoriaPlantilla"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/border_image" />

        <Spinner
            android:id="@+id/spinnerGrupoPlantilla"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/border_image" />

        <Spinner
            android:id="@+id/spinnerImagenPlantilla"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/border_image" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.SportsGO.KineticInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Series">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSeriesPlantilla"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="@color/kinetic_on_surface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.SportsGO.KineticInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Repeticiones">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRepsPlantilla"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="@color/kinetic_on_surface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.SportsGO.KineticInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Peso recomendado (ej: 40kg)">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPesoPlantilla"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/kinetic_on_surface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.SportsGO.KineticInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="URL tecnica (opcional)"
            app:startIconDrawable="@android:drawable/ic_media_play"
            app:startIconTint="@color/kinetic_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etVideoPlantilla"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:textColor="@color/kinetic_on_surface" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>
</ScrollView>
