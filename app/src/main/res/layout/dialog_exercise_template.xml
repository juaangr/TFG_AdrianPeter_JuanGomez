<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <EditText
            android:id="@+id/etNombrePlantilla"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Nombre del ejercicio" />

        <Spinner
            android:id="@+id/spinnerCategoriaPlantilla"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@android:drawable/btn_dropdown" />

        <Spinner
            android:id="@+id/spinnerGrupoPlantilla"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@android:drawable/btn_dropdown" />

        <Spinner
            android:id="@+id/spinnerImagenPlantilla"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@android:drawable/btn_dropdown" />

        <EditText
            android:id="@+id/etSeriesPlantilla"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:hint="Series"
            android:inputType="number" />

        <EditText
            android:id="@+id/etRepsPlantilla"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:hint="Repeticiones"
            android:inputType="number" />

        <EditText
            android:id="@+id/etPesoPlantilla"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:hint="Peso recomendado (ej: 40kg)" />

        <EditText
            android:id="@+id/etVideoPlantilla"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:hint="URL tecnica (opcional)"
            android:inputType="textUri" />
    </LinearLayout>
</ScrollView>

