<?xml version="1.0" encoding="utf-8"?>
<!-- Fondo de apoyo para activity_trainer_assign_workout: base oscura + glow neón suave. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/kinetic_surface" />
        </shape>
    </item>

    <item android:bottom="-140dp" android:right="-100dp">
        <shape android:shape="oval">
            <size android:width="340dp" android:height="340dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="170dp"
                android:startColor="#26CAFD00"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>

