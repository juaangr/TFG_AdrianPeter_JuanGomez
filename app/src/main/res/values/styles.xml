<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.SportsGO.KineticCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/kinetic_card</item>
        <item name="strokeColor">@color/kinetic_border_soft</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">8dp</item>
    </style>

    <style name="Widget.SportsGO.KineticInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/kinetic_card_alt</item>
        <item name="boxStrokeColor">@color/kinetic_primary</item>
        <item name="hintTextColor">@color/kinetic_text_gray</item>
    </style>

    <style name="Widget.SportsGO.KineticButtonPrimary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/kinetic_primary</item>
        <item name="android:textColor">@color/black</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="Widget.SportsGO.KineticButtonDark" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/kinetic_card_alt</item>
        <item name="android:textColor">@color/kinetic_on_surface</item>
        <item name="strokeColor">@color/kinetic_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">14dp</item>
    </style>

</resources>

